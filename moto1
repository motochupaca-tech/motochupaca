<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="referrer" content="no-referrer" />
  <title>Reproductor Definitivo</title>
  <style>
    body, html { margin: 0; padding: 0; width: 100%; height: 100%; background-color: #000; overflow: hidden; }
    video { width: 100%; height: 100%; outline: none; }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
</head>
<body>

  <video id="main-video" controls playsinline></video>

  <script>
    const video = document.getElementById('main-video');
    const streamUrl = "https://livecdn.euw1-0005.jwplive.com/live/sites/fM9jRrkn/media/Q0ZBRhLW/live.isml/.m3u8";

    if (Hls.isSupported()) {
      const hls = new Hls({
        fetchSetup: function(context, initParams) {
          
          // Proxy Parcial usando tu propio servidor interno
          if (context.url.includes('.m3u8') || context.url.includes('.m3u') || context.url.includes('.isml')) {
            context.url = '/api/proxy?url=' + encodeURIComponent(context.url);
          }

          initParams = initParams || {};
          initParams.headers = new Headers(initParams.headers || {});
          initParams.headers.set("Accept", "*/*");
          
          return new Request(context.url, initParams);
        }
      });

      hls.loadSource(streamUrl);
      hls.attachMedia(video);

      hls.on(Hls.Events.MANIFEST_PARSED, function() {
        video.play().catch(e => console.log("Requiere clic del usuario", e));
      });

    } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
      video.src = '/api/proxy?url=' + encodeURIComponent(streamUrl);
      video.addEventListener('loadedmetadata', function() {
        video.play();
      });
    }
  </script>
</body>
</html>
